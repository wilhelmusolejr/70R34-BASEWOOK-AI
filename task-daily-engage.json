{
  "taskId": "engage-and-add",
  "profilesFromStatus": "Active",
  "profiles": [],
  "cooldown": { "shareHours": 24 },
  "concurrency": 6,
  "openStaggerSeconds": 60,
  "blockMedia": true,
  "steps": [
    {
      "type": "homepage_interaction",
      "steps": [
        { "type": "scroll", "params": { "min": 20, "max": 40 } },
        { "type": "like_posts", "params": { "min": 1, "max": 3 } }
      ]
    },

    {
      "type": "setup_privacy",
      "guard": { "ifOnboardingMissing": "privacyPublicAt" }
    },

    {
      "type": "setup_about",
      "guard": { "ifOnboardingMissing": "aboutSetAt", "minAccountAgeDays": 2 },
      "chance": 0.5
    },

    {
      "type": "setup_avatar",
      "guard": { "ifOnboardingMissing": "profileImageSetAt", "minAccountAgeDays": 3 },
      "chance": 0.3
    },

    {
      "type": "setup_cover",
      "guard": { "ifOnboardingMissing": "coverImageSetAt", "minAccountAgeDays": 3 },
      "chance": 0.3
    },

    { "type": "wait", "params": { "min": 20, "max": 40 } },

    { "type": "accept_loop" },

    { "type": "wait", "params": { "min": 30, "max": 60 } },

    {
      "type": "search",
      "params": { "mode": "general" },
      "steps": [
        { "type": "scroll", "params": { "min": 40, "max": 70 } },
        { "type": "like_posts", "params": { "min": 1, "max": 3 } }
      ]
    },

    { "type": "wait", "params": { "min": 30, "max": 60 } },

    {
      "type": "visit_profile",
      "params": { "pool": "sharers" },
      "steps": [
        { "type": "connect" },
        { "type": "scroll", "params": { "min": 30, "max": 60 } },
        { "type": "like_posts", "params": { "min": 1, "max": 4 } },
        { "type": "share_posts", "params": { "count": 1 } }
      ]
    },

    { "type": "wait", "params": { "min": 30, "max": 60 } },

    {
      "type": "search",
      "params": { "mode": "page", "filter": "Pages" },
      "steps": [
        { "type": "scroll", "params": { "min": 20, "max": 40 } },
        { "type": "open_search_result" },
        { "type": "scroll", "params": { "min": 20, "max": 40 } },
        { "type": "connect" }
      ]
    },

    { "type": "wait", "params": { "min": 30, "max": 60 } },

    {
      "type": "visit_profile",
      "params": { "pool": "sharers" },
      "steps": [
        { "type": "connect" },
        { "type": "scroll", "params": { "min": 30, "max": 60 } },
        { "type": "like_posts", "params": { "min": 1, "max": 4 } },
        { "type": "share_posts", "params": { "count": 1 } }
      ]
    },

    { "type": "wait", "params": { "min": 30, "max": 60 } },

    { "type": "connect_loop", "params": { "count": 7, "skipIfFriendsAbove": 30 } },

    { "type": "wait", "params": { "min": 30, "max": 60 } },

    {
      "type": "create_page",
      "guard": { "ifFieldEmpty": "pageUrl" },
      "chance": 0.5,
      "params": { "allowedFailures": 0 },
      "steps": [{ "type": "switch_profile" }]
    }
  ]
}
