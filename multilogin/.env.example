# Multilogin helper scripts read .env from this folder when run inside multilogin/.
MLX_EMAIL=
MLX_PASSWORD=
WORKSPACE_ID=
FOLDER_ID=

# App API used by helper scripts for user/profile records.
API_BASE=https://7or34.space

# Optional creation/search settings.
BROWSER_TYPE=mimic
OS_TYPE=windows
CORE_VERSION=130
PROFILES_FILE=profiles.json
PROFILE_IDS_FILE=profile_ids.json
OUTPUT_FILE=profile_ids.json
CREATE_DELAY_MS=2000

# Optional proxy assignment settings.
PROXY_PROTOCOL=socks5
PROXY_DELAY_MS=1500
DRY_RUN=false
LIMIT=
