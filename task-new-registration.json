        { "type": "scroll", "params": { "min": 30, "max": 50 } }
      ]
    },

    { "type": "wait", "params": { "min": 30, "max": 60 } },

    {
      "type": "homepage_interaction",
      "steps": [
        { "type": "scroll", "params": { "min": 20, "max": 40 } }
      ]
